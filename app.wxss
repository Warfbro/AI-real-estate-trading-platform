page {
  background: #FAF8F5;
  color: #2F241D;
  font-size: 28rpx;
  width: 100%;
  overflow-x: hidden;
}

.page {
  padding: 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #4A3328;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #5E473A;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 28rpx rgba(92, 64, 51, 0.10);
  border: 2rpx solid rgba(92, 64, 51, 0.16);
  margin-bottom: 32rpx;
  transition: box-shadow 0.3s ease, opacity 0.3s ease;
}

.card-hover {
  box-shadow: 0 18rpx 40rpx rgba(92, 64, 51, 0.18) !important;
}

.btn-primary {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #4E382C;
  color: #FFFFFF;
  font-weight: bold;
  font-size: 32rpx;
  padding: 12rpx 0;
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(78, 56, 44, 0.26);
  transition: box-shadow 0.3s ease, opacity 0.3s ease;
}

.btn-secondary {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #DCC6B6;
  color: #4A3328;
  font-weight: bold;
  font-size: 32rpx;
  padding: 12rpx 0;
  border: 2rpx solid rgba(92, 64, 51, 0.22);
  box-shadow: 0 10rpx 24rpx rgba(92, 64, 51, 0.14);
  transition: box-shadow 0.3s ease, opacity 0.3s ease;
}

.btn-hover, .button-hover, .click-hover {
  box-shadow: 0 16rpx 30rpx rgba(92, 64, 51, 0.28) !important;
  opacity: 0.9 !important;
}

.label {
  font-size: 28rpx;
  color: #4A3328;
  margin-bottom: 12rpx;
  font-weight: bold;
  display: block;
}

.input,
.textarea {
  width: 100%;
  border: 2rpx solid rgba(92, 64, 51, 0.20);
  border-radius: 16rpx;
  background: #FFFDF9;
  padding: 20rpx;
  box-sizing: border-box;
  color: #2F241D;
  box-shadow: inset 0 2rpx 10rpx rgba(92, 64, 51, 0.04);
  transition: all 0.2s ease;
}

.input:focus, .textarea:focus {
  border-color: #4A3328;
  box-shadow: 0 0 0 4rpx rgba(92, 64, 51, 0.16), inset 0 2rpx 10rpx rgba(92, 64, 51, 0.04);
}

.textarea {
  min-height: 220rpx;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row .input {
  flex: 1;
}

.hint {
  font-size: 24rpx;
  color: #6B5448;
  margin-top: 8rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #DCC6B6;
  color: #4A3328;
  font-size: 22rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

/* Global States */
.empty-state,
.error-state,
.unauth-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
  text-align: center;
}

.empty-state .state-title,
.error-state .state-title,
.unauth-state .state-title {
  font-size: 32rpx;
  color: #4A3328;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.empty-state .state-desc,
.error-state .state-desc,
.unauth-state .state-desc {
  font-size: 28rpx;
  color: #5E473A;
  margin-bottom: 32rpx;
}
