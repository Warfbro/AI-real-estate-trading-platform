page {
  background: #F7F8FA;
  color: #333333;
  font-size: 28rpx;
}

.page {
  padding: 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #5C4033;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #7A6355;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
  margin-bottom: 32rpx;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease;
}

.card-hover {
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.06) !important;
}

.btn-primary {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #5C4033;
  color: #FFFFFF;
  font-weight: bold;
  font-size: 32rpx;
  padding: 12rpx 0;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(92, 64, 51, 0.15);
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease;
}

.btn-secondary {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #E4D4C8;
  color: #5C4033;
  font-weight: bold;
  font-size: 32rpx;
  padding: 12rpx 0;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(228, 212, 200, 0.3);
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease;
}

.btn-hover, .button-hover, .click-hover {
  box-shadow: 0 16rpx 32rpx rgba(92, 64, 51, 0.25) !important;
  opacity: 0.85 !important;
}

.label {
  font-size: 28rpx;
  color: #5C4033;
  margin-bottom: 12rpx;
  font-weight: bold;
  display: block;
}

.input,
.textarea {
  width: 100%;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 16rpx;
  background: #ffffff;
  padding: 20rpx;
  box-sizing: border-box;
  color: #333333;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  transition: all 0.2s ease;
}

.input:focus, .textarea:focus {
  border-color: #5C4033;
  box-shadow: 0 0 0 4rpx rgba(92, 64, 51, 0.1), inset 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.textarea {
  min-height: 220rpx;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row .input {
  flex: 1;
}

.hint {
  font-size: 24rpx;
  color: #8C7A6B;
  margin-top: 8rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #E4D4C8;
  color: #5C4033;
  font-size: 22rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

/* Global States */
.empty-state,
.error-state,
.unauth-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
  text-align: center;
}

.empty-state .state-title,
.error-state .state-title,
.unauth-state .state-title {
  font-size: 32rpx;
  color: #5C4033;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.empty-state .state-desc,
.error-state .state-desc,
.unauth-state .state-desc {
  font-size: 28rpx;
  color: #7A6355;
  margin-bottom: 32rpx;
}
