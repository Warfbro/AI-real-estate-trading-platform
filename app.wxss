page {
  background:
    radial-gradient(
      130% 72% at 12% -10%,
      rgba(199, 212, 230, 0.82) 0%,
      rgba(213, 224, 238, 0.66) 34%,
      rgba(242, 236, 225, 0.18) 72%,
      rgba(248, 243, 234, 0) 100%
    ),
    linear-gradient(180deg, #d9e3f0 0%, #e2e9f2 30%, #eef1f4 58%, #f7f4ed 100%);
  color: #2c3546;
  font-size: 28rpx;
  width: 100%;
  overflow-x: hidden;
}

.page {
  padding: 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
  background:
    radial-gradient(
      130% 72% at 12% -10%,
      rgba(199, 212, 230, 0.82) 0%,
      rgba(213, 224, 238, 0.66) 34%,
      rgba(242, 236, 225, 0.18) 72%,
      rgba(248, 243, 234, 0) 100%
    ),
    linear-gradient(180deg, #d9e3f0 0%, #e2e9f2 30%, #eef1f4 58%, #f7f4ed 100%);
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #243247;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6b7a8f;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 28rpx rgba(102, 123, 156, 0.12);
  border: 2rpx solid rgba(205, 217, 235, 0.96);
  margin-bottom: 32rpx;
  transition: box-shadow 0.3s ease, opacity 0.3s ease;
}

.card-hover {
  box-shadow: 0 18rpx 40rpx rgba(102, 123, 156, 0.22) !important;
}

.btn-primary {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ff9a57 0%, #ff651c 100%);
  color: #FFFFFF;
  font-weight: bold;
  font-size: 32rpx;
  padding: 12rpx 0;
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(255, 122, 48, 0.26);
  transition: box-shadow 0.3s ease, opacity 0.3s ease;
}

.btn-secondary {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #31507b;
  font-weight: bold;
  font-size: 32rpx;
  padding: 12rpx 0;
  border: 2rpx solid rgba(198, 212, 234, 0.96);
  box-shadow: 0 10rpx 24rpx rgba(102, 123, 156, 0.10);
  transition: box-shadow 0.3s ease, opacity 0.3s ease;
}

.btn-hover, .button-hover, .click-hover {
  box-shadow: 0 16rpx 30rpx rgba(102, 123, 156, 0.22) !important;
  opacity: 0.9 !important;
}

.label {
  font-size: 28rpx;
  color: #31507b;
  margin-bottom: 12rpx;
  font-weight: bold;
  display: block;
}

.input,
.textarea {
  width: 100%;
  border: 2rpx solid rgba(198, 212, 234, 0.96);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  padding: 20rpx;
  box-sizing: border-box;
  color: #2c3546;
  box-shadow: inset 0 2rpx 10rpx rgba(127, 150, 184, 0.08);
  transition: all 0.2s ease;
}

.input:focus, .textarea:focus {
  border-color: #8eaed8;
  box-shadow: 0 0 0 4rpx rgba(142, 174, 216, 0.18), inset 0 2rpx 10rpx rgba(127, 150, 184, 0.08);
}

.textarea {
  min-height: 220rpx;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row .input {
  flex: 1;
}

.hint {
  font-size: 24rpx;
  color: #6f7f93;
  margin-top: 8rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(214, 224, 239, 0.92);
  color: #3d577f;
  font-size: 22rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

/* Global States */
.empty-state,
.error-state,
.unauth-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
  text-align: center;
}

.empty-state .state-title,
.error-state .state-title,
.unauth-state .state-title {
  font-size: 32rpx;
  color: #243247;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.empty-state .state-desc,
.error-state .state-desc,
.unauth-state .state-desc {
  font-size: 28rpx;
  color: #6b7a8f;
  margin-bottom: 32rpx;
}
