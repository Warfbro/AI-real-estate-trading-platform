.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(104rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.97);
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -8rpx 24rpx rgba(92, 64, 51, 0.14);
  z-index: 1000;
}

.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(214, 199, 186, 0.6);
}

.tab-bar-item {
  flex: 1;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.icon {
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 6rpx;
  background-color: #ccbcae;
  mask-size: cover;
  -webkit-mask-size: cover;
}

.active .icon {
  background-color: #f06a23;
}

/* 简单的 CSS 占位图标 */
.home-icon {
  border-radius: 6rpx;
}
.my-icon {
  border-radius: 50%;
}

.text {
  font-size: 22rpx;
  color: #b6a89b;
}

.active .text {
  color: #f06a23;
  font-weight: 600;
}

.ai-btn-wrapper {
  position: relative;
}

.ai-button {
  position: absolute;
  top: -40rpx;
  left: 50%;
  margin-left: -55rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ff9a57 0%, #ff651c 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 14rpx 30rpx rgba(173, 111, 79, 0.38);
  border: 8rpx solid #f8f1e7;
  transition: box-shadow 0.3s ease, opacity 0.3s ease;
}
