.action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.btn-action {
  width: calc(50% - 8rpx);
  border-radius: 16rpx;
  border: 2rpx solid #E4D4C8;
  background: #ffffff;
  color: #5C4033;
  margin: 0;
  font-weight: bold;
}

.btn-action-active {
  background: #5C4033;
  color: #ffffff;
  border-color: #5C4033;
}

.history-item {
  border-bottom: 2rpx solid #E4D4C8;
  padding: 16rpx 0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.btn-inline {
  width: auto;
  margin-top: 16rpx;
  margin-bottom: 0;
  padding: 0 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #E4D4C8;
  color: #5C4033;
  font-weight: bold;
}

.warn {
  color: #D97706; /* Warmer orange/brown warning tone */
}
