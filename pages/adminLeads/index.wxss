.picker {
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
  color: #1f2937;
}

.lead-item {
  border-bottom: 1rpx solid #e5e7eb;
  padding: 16rpx 0 20rpx;
}

.lead-item:last-child {
  border-bottom: 0;
}

.lead-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.quick-filter-btn {
  margin-bottom: 8rpx;
}

.quick-filter-hint {
  margin-bottom: 18rpx;
}
