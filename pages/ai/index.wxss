
page { background-color: #F7F8FA; height: 100vh; overflow: hidden; }
.page-container { position: relative; width: 100%; height: 100%; background-color: transparent; }
.circle-anim-bg { position: absolute; left: 50%; bottom: 0rpx; width: 100rpx; height: 100rpx; margin-left: -50rpx; border-radius: 50%; background-color: #F7F8FA; z-index: 1; animation: expandCircle 0.82s cubic-bezier(0.25, 1, 0.4, 1) forwards; }
@keyframes expandCircle { 0% { transform: scale(1); } 100% { transform: scale(38); } }

.nav-bar-wrapper { position: absolute; left: 0; top: 0; width: 100%; z-index: 100; background-color: #F7F8FA; box-shadow: 0 4rpx 16rpx rgba(92, 64, 51, 0.03); }
.nav-bar-inner { display: flex; align-items: center; justify-content: space-between; width: 100%; box-sizing: border-box; }
.nav-left { display: flex; align-items: center; height: 100%; padding-left: 30rpx; box-sizing: border-box; }
.nav-right { display: flex; align-items: center; height: 100%; }
.nav-title { font-size: 34rpx; font-weight: 600; color: #333333; flex: 1; text-align: center; }
.back-icon { font-size: 56rpx; font-weight: 300; color: #5C4033; }

.chat-core { position: absolute; left: 0; right: 0; bottom: 0; z-index: 10; display: flex; flex-direction: column; background: #F7F8FA; overflow: hidden; }
.chat-scroll { flex: 1; overflow: hidden; box-sizing: border-box; }
/* 关键修复 1：将顶栏聊天内容往下推 90rpx，避开页眉长期待在顶部时的遮挡遮盖 */
.chat-list { padding: 90rpx 30rpx 40rpx; } 
.chat-msg { display: flex; margin-bottom: 40rpx; align-items: flex-start; }
.ai-msg { flex-direction: row; }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background-color: #5C4033; color: #F7F8FA; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: bold; margin-right: 20rpx; flex-shrink: 0; box-shadow: 0 4rpx 12rpx rgba(92, 64, 51, 0.1); }
.msg-bubble { background-color: #ffffff; padding: 24rpx 32rpx; border-radius: 0 32rpx 32rpx 32rpx; font-size: 30rpx; color: #333333; line-height: 1.65; box-shadow: 0 12rpx 32rpx rgba(92, 64, 51, 0.04); max-width: 78%; }

.chat-mask { position: absolute; left: 0; width: 100%; bottom: 0; background-color: #000000; z-index: 20; pointer-events: none; }

.blind-drawer {
  position: absolute; left: 0; width: 100%; z-index: 50;
  background: #ffffff; border-radius: 0 0 40rpx 40rpx; /* 外观更圆�?*/
  box-shadow: 0 20rpx 60rpx rgba(92,64,51,0.1); 
  display: flex; flex-direction: column;
  padding-top: 1000px; margin-top: -1000px;
}
.history-content { width: 100%; display: flex; flex-direction: column; overflow: hidden; }
.drawer-content-inner { flex: 1; padding: 40rpx; display: flex; flex-direction: column; box-sizing: border-box; overflow: hidden; }
.drawer-header-text { font-size: 28rpx; color: #333333; margin-bottom: 24rpx; font-weight: 600; }
.drawer-btn { width: 100%; height: 88rpx; flex-shrink: 0; background-color: #E4D4C8; color: #5C4033; display: flex; align-items: center; justify-content: center; border-radius: 44rpx; font-size: 30rpx; margin-bottom: 30rpx; font-weight: 500; }
.drawer-list { flex: 1; overflow-y: auto;}
.drawer-item { display: flex; flex-direction: column; gap: 12rpx; padding: 28rpx 20rpx; border-bottom: 1rpx solid rgba(92,64,51,0.05); background-color: #F7F8FA; border-radius: 20rpx; margin-bottom: 20rpx; }
.drawer-time { font-size: 22rpx; color: #A0A0A0; }
.drawer-desc { font-size: 28rpx; color: #333333; }

/* 关键修复 2：把页眉做窄做精致，减小视觉占用 */
.swipe-header {
  width: 100%; padding: 12rpx 0 16rpx 0; background: #ffffff; 
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  border-top: 1rpx solid rgba(92,64,51,0.02); border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 6rpx 16rpx rgba(92, 64, 51, 0.05);
}
.swipe-header text { font-size: 20rpx; color: #999999; letter-spacing: 2rpx; margin-bottom: 8rpx; font-weight: 300; transition: color 0.3s; }
.swipe-header.down text, .swipe-header.up text { color: #A89582; }

/* 关键修复 3：连续不断的无缝箭头变形计算，采�?55% 互相覆盖并中心咬�?*/
.swipe-indicator { width: 44rpx; height: 6rpx; position: relative; }
.swipe-indicator::before, .swipe-indicator::after { 
  content: ''; position: absolute; top: 0; width: 55%; height: 100%; 
  background-color: #D4C4B8; border-radius: 6rpx; 
  transition: transform 0.3s cubic-bezier(0.25, 1.05, 0.5, 1), background-color 0.3s; 
}
.swipe-indicator::before { left: 0; transform-origin: 100% 50%; }
.swipe-indicator::after { right: 0; transform-origin: 0% 50%; }

/* 下推时，变形�?V 状向下箭�?(指引方向) */
.swipe-header.down .swipe-indicator::before { transform: rotate(-30deg); background-color: #D1B8A4; }
.swipe-header.down .swipe-indicator::after { transform: rotate(30deg); background-color: #D1B8A4; }

/* 上推收起时，变形�?^ 状向上箭�?*/
.swipe-header.up .swipe-indicator::before { transform: rotate(30deg); background-color: #D1B8A4; }
.swipe-header.up .swipe-indicator::after { transform: rotate(-30deg); background-color: #D1B8A4; }

.input-area { background-color: #ffffff; padding-bottom: env(safe-area-inset-bottom); box-shadow: 0 -4rpx 24rpx rgba(92, 64, 51, 0.05); transition: border-radius 0.4s ease; border-radius: 40rpx 40rpx 0 0; position: relative; z-index: 10; }
.input-row { display: flex; padding: 24rpx 30rpx; align-items: center; }
.chat-input { flex: 1; background-color: #F7F8FA; height: 84rpx; border-radius: 42rpx; padding: 0 40rpx; font-size: 30rpx; color: #333333; }
.add-btn { width: 68rpx; height: 68rpx; border-radius: 50%; background-color: #E4D4C8; color: #5C4033; font-size: 48rpx; font-weight: 300; display: flex; align-items: center; justify-content: center; margin-left: 24rpx; transition: transform 0.5s cubic-bezier(0.25, 1, 0.4, 1), background-color 0.4s; line-height: 1; padding-bottom: 6rpx; }
.input-area.has-panel .add-btn { transform: rotate(135deg); background-color: #F7F8FA; }

.more-panel { height: 280rpx; background-color: #ffffff; display: flex; padding: 30rpx 60rpx; gap: 80rpx; border-top: 1rpx solid rgba(92,64,51,0.03); animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
@keyframes slideUp { from { opacity: 0; transform: translateY(40rpx); } to { opacity: 1; transform: translateY(0); } }
.panel-item { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.icon-box { width: 116rpx; height: 116rpx; border-radius: 36rpx; background-color: #F7F8FA; display: flex; align-items: center; justify-content: center; color: #5C4033; box-shadow: inset 0 2rpx 8rpx rgba(92, 64, 51, 0.02); transition: transform 0.2s; font-size:42rpx; }
.icon-box:active { transform: scale(0.95); }
.panel-item text { font-size: 24rpx; color: #666666; }
