<view class="page">
  <view class="title">房源比较</view>
  <view class="subtitle">选择 2~5 套房源，生成差异矩阵与推荐顺序。</view>

  <view class="card">
    <view class="label">已选房源</view>
    <view class="hint">{{selected_count_text}} 套</view>
    <view class="hint">规则：少于2套无法生成正式比较，超过5套需先减少。</view>
    <view class="row">
      <button class="btn-secondary" bindtap="handleGoCandidates">返回候选页</button>
      <button class="btn-primary" bindtap="handleGenerateCompare">生成比较</button>
    </view>
  </view>

  <view class="card" wx:if="{{has_selected_listings}}">
    <view class="label">比较对象</view>
    <block wx:for="{{selected_listings}}" wx:key="listing_id">
      <view class="hint">{{item.display_line}}</view>
    </block>
  </view>

  <view class="card" wx:if="{{generated}}">
    <view class="label">差异矩阵</view>
    <block wx:for="{{matrix_rows}}" wx:key="label">
      <view class="{{item.row_class}}">
        <view class="matrix-label">{{item.label}}</view>
        <block wx:for="{{item.values}}" wx:key="*this">
          <view class="matrix-cell">{{item}}</view>
        </block>
      </view>
    </block>
  </view>

  <view class="card" wx:if="{{generated}}">
    <view class="label">推荐顺序</view>
    <block wx:for="{{ranking}}" wx:key="listing_id">
      <view class="rank-item">
        <view class="rank-title">{{item.rank_index_text}} {{item.title}}</view>
        <view class="hint">评分：{{item.score}}</view>
        <view class="hint">理由：{{item.reason_text}}</view>
      </view>
    </block>
  </view>

  <view class="card" wx:if="{{generated}}">
    <view class="label">牺牲点与继续确认问题</view>
    <block wx:for="{{tradeoffs}}" wx:key="*this">
      <view class="hint">- {{item}}</view>
    </block>
    <view class="label space-top">继续确认问题</view>
    <block wx:for="{{followup_questions}}" wx:key="*this">
      <view class="hint">- {{item}}</view>
    </block>
  </view>

  <view class="row" wx:if="{{generated}}">
    <button class="btn-primary" bindtap="handleSaveCompare">保存比较</button>
    <button class="btn-secondary" bindtap="handleGoRisk">进入风险确认</button>
  </view>

  <view class="card" wx:if="{{saved}}">
    <view class="hint">已保存 comparison_id：{{last_comparison_id}}</view>
  </view>
</view>
