<view class="detail-page">
  <block wx:if="{{has_listing}}">
    <view class="hero-block">
      <swiper
        wx:if="{{has_media}}"
        class="hero-swiper"
        indicator-dots="true"
        autoplay="false"
        circular="false"
        indicator-color="rgba(255,255,255,0.45)"
        indicator-active-color="#ffffff"
      >
        <block wx:for="{{media_list}}" wx:key="url">
          <swiper-item>
            <view class="hero-slide">
              <video
                wx:if="{{item.type === 'video'}}"
                class="hero-media"
                src="{{item.url}}"
                controls
                object-fit="cover"
                show-center-play-btn
              />
              <image
                wx:else
                class="hero-media"
                src="{{item.url}}"
                mode="aspectFill"
              />
            </view>
          </swiper-item>
        </block>
      </swiper>

      <view wx:else class="hero-empty">
        <view class="hero-empty-title">暂无图片/视频</view>
      </view>

      <view class="hero-overlay">
        <view class="hero-title">{{display_title}}</view>
        <view class="hero-sub">{{display_price}} · {{display_area}}</view>
      </view>
    </view>

    <view class="info-card">
      <view class="section-title">一般信息</view>
      <view class="info-grid">
        <view class="info-item">
          <view class="info-key">户型</view>
          <view class="info-value">{{display_layout}}</view>
        </view>
        <view class="info-item">
          <view class="info-key">面积</view>
          <view class="info-value">{{display_area}}</view>
        </view>
        <view class="info-item">
          <view class="info-key">楼层</view>
          <view class="info-value">{{display_floor}}</view>
        </view>
        <view class="info-item">
          <view class="info-key">朝向</view>
          <view class="info-value">{{display_orientation}}</view>
        </view>
        <view class="info-item full">
          <view class="info-key">位置</view>
          <view class="info-value">{{display_position}}</view>
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="section-title">上传者提供详情</view>
      <view class="uploader-text">{{raw_text_display}}</view>
    </view>
  </block>

  <view class="info-card" wx:else>
    <view class="section-title">未找到该房源</view>
    <view class="uploader-text">请返回上一页重新选择房源。</view>
  </view>
</view>
