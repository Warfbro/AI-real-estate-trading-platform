.detail-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 0 calc(186rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(
      130% 70% at 12% -10%,
      rgba(203, 214, 229, 0.95) 0%,
      rgba(218, 226, 237, 0.82) 34%,
      rgba(243, 240, 232, 0.2) 72%,
      rgba(247, 242, 233, 0) 100%
    ),
    linear-gradient(180deg, #d8e2ef 0%, #e2e7ed 48%, #f7f3ea 100%);
}

.hero-block {
  position: relative;
  width: 100%;
  height: 72vh;
  min-height: 720rpx;
  max-height: 1120rpx;
  overflow: hidden;
  background: #d9e4f0;
}

.hero-swiper {
  width: 100%;
  height: 100%;
}

.hero-slide {
  width: 100%;
  height: 100%;
}

.hero-media {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #dbe5f2 0%, #eef2f6 100%);
}

.hero-empty-title {
  font-size: 32rpx;
  color: #6a594d;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 36rpx 30rpx 34rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(28, 23, 18, 0) 0%, rgba(28, 23, 18, 0.66) 100%);
}

.hero-title {
  font-size: 42rpx;
  line-height: 1.3;
  color: #ffffff;
  font-weight: 600;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 500;
}

.info-card {
  margin: 24rpx 20rpx 0;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 10rpx 24rpx rgba(102, 123, 156, 0.12);
}

.section-title {
  font-size: 30rpx;
  color: #2f261f;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 12rpx;
}

.info-item {
  width: calc(50% - 6rpx);
  padding: 16rpx 14rpx;
  border-radius: 14rpx;
  box-sizing: border-box;
  background: rgba(233, 239, 248, 0.92);
}

.info-item.full {
  width: 100%;
}

.info-key {
  font-size: 22rpx;
  color: #7a8ca4;
}

.info-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #2f261f;
  font-weight: 500;
  word-break: break-word;
}

.uploader-text {
  white-space: pre-wrap;
  word-break: break-word;
  font-size: 26rpx;
  line-height: 1.68;
  color: #2f261f;
}
