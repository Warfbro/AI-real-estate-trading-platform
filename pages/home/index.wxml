<view class="page">
  <view class="search-bar" bindtap="handleSearch" hover-class="card-hover">
    <icon class="search-icon" type="search" size="14" color="#999" />
    <view class="search-text">搜索感兴趣的房源或区域</view>
  </view>

  <view class="horizontal-section">
    <view class="section-title">热门房源</view>
    <scroll-view class="hot-scroll" scroll-x="true">
      <block wx:if="{{has_hot_listings}}">
        <block wx:for="{{hot_listings}}" wx:key="listing_id">
          <view class="h-card card" bindtap="handleOpenListing" data-listing-id="{{item.listing_id}}" hover-class="card-hover">
            <image wx:if="{{item.cover_image_url}}" class="h-img" src="{{item.cover_image_url}}" mode="aspectFill"></image>
            <view wx:else class="h-img h-img-placeholder"></view>
            <view class="h-info">
              <view class="h-title">{{item.title_text}}</view>
              <view class="h-desc">{{item.hot_desc_text}}</view>
            </view>
          </view>
        </block>
      </block>
      <view wx:else class="h-card card h-card-empty">
        <view class="h-info">
          <view class="h-title">暂无热门房源</view>
          <view class="h-desc">请稍后刷新重试</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="hot-properties-section">
    <view class="section-title">猜你喜欢</view>
    <view wx:if="{{guess_strategy_text}}" class="strategy-text">{{guess_strategy_text}}</view>
    <block wx:if="{{has_guess_listings}}">
      <block wx:for="{{guess_listings}}" wx:key="listing_id">
        <view class="card property-item" bindtap="handleOpenListing" data-listing-id="{{item.listing_id}}" hover-class="card-hover">
          <image wx:if="{{item.cover_image_url}}" class="item-img" src="{{item.cover_image_url}}" mode="aspectFill"></image>
          <view wx:else class="item-img item-img-placeholder"></view>
          <view class="item-info">
            <view class="item-title">{{item.title_text}}</view>
            <view class="item-desc">{{item.guess_desc_text}}</view>
          </view>
        </view>
      </block>
    </block>
    <view wx:else class="card empty-block">暂无可推荐房源，请先导入房源。</view>
  </view>
</view>
