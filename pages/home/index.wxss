.page {
  background-color: #F7F8FA;
  min-height: 100vh;
  padding: 24rpx 16rpx;
  box-sizing: border-box;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 999rpx;
  padding: 16rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease;
}

.search-bar-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  margin-right: 12rpx;
}

.search-text {
  flex: 1;
  font-size: 28rpx;
  color: #999999;
}

.horizontal-section {
  margin-top: 16rpx;
  margin-bottom: 32rpx;
}

.hot-scroll {
  white-space: nowrap;
  width: 100%;
  padding-left: 16rpx;
  box-sizing: border-box;
}

.h-card {
  display: inline-block;
  width: 300rpx;
  margin-right: 24rpx;
  padding: 0;
  border-radius: 20rpx;
  background-color: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
  overflow: hidden;
  vertical-align: top;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease;
}

.h-card:last-child {
  margin-right: 16rpx;
}

.h-card-empty {
  width: 520rpx;
  min-height: 160rpx;
}

.h-img {
  width: 100%;
  height: 200rpx;
  background-color: #F0F2F5;
  display: block;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
}

.h-img-placeholder {
  background-color: #F0F2F5;
}

.h-info {
  padding: 20rpx;
}

.h-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  white-space: normal;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.h-desc {
  font-size: 24rpx;
  color: #999999;
}

.hot-properties-section {
  margin-top: 32rpx;
}

.strategy-text {
  margin: 0 16rpx 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 24rpx;
  padding: 0 16rpx;
}

.property-item {
  display: flex;
  margin-bottom: 24rpx;
  padding: 24rpx;
  align-items: stretch;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease;
}

.card-hover {
  transform: translateY(-4rpx) !important;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.06) !important;
}

.item-img {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background-color: #F0F2F5;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.item-img-placeholder {
  background-color: #F0F2F5;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-desc {
  font-size: 26rpx;
  color: #999999;
}

.empty-block {
  margin: 0 16rpx;
  color: #999999;
  font-size: 26rpx;
}
