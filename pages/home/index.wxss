.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 22rpx 20rpx calc(220rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(
      130% 72% at 12% -10%,
      rgba(199, 212, 230, 0.95) 0%,
      rgba(213, 224, 238, 0.82) 35%,
      rgba(236, 234, 227, 0.25) 72%,
      rgba(245, 240, 231, 0) 100%
    ),
    linear-gradient(
      180deg,
      #d6e0ef 0%,
      #dde6f2 28%,
      #e7e8e7 52%,
      #f2ece1 74%,
      #f8f3ea 100%
    );
}

.search-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 8rpx 2rpx 12rpx;
}

.address-pill {
  width: 154rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  padding: 0 14rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 1rpx solid rgba(220, 220, 220, 0.75);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 22rpx rgba(92, 64, 51, 0.1);
}

.address-icon {
  margin-right: 6rpx;
  flex-shrink: 0;
}

.address-text {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #615349;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.search-bar {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 1rpx solid rgba(220, 220, 220, 0.75);
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 10rpx 22rpx rgba(92, 64, 51, 0.1);
}

.search-icon {
  margin-right: 10rpx;
}

.search-text {
  flex: 1;
  font-size: 25rpx;
  color: #8c8f97;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.search-hover {
  opacity: 0.86;
}

.location-hint {
  margin: 6rpx 6rpx 0;
  font-size: 22rpx;
  color: #7d6f65;
}

.horizontal-section {
  margin-top: 16rpx;
  margin-bottom: 28rpx;
}

.section-title {
  padding: 0 8rpx;
  margin-bottom: 14rpx;
  font-size: 52rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #2a211b;
}

.hot-swiper {
  width: 100%;
  height: 470rpx;
}

.hot-swiper-item {
  height: 100%;
  padding: 2rpx 4rpx;
  box-sizing: border-box;
}

.h-card {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 10rpx 24rpx rgba(92, 64, 51, 0.12);
  overflow: hidden;
  border: 1rpx solid rgba(233, 224, 214, 0.85);
  box-sizing: border-box;
}

.h-card-empty {
  width: 100%;
  min-height: 260rpx;
}

.h-img {
  width: 100%;
  height: 292rpx;
  display: block;
  background: #ebe5dc;
}

.h-img-placeholder {
  background: linear-gradient(145deg, #efe9df 0%, #e4d9cb 100%);
}

.h-info {
  padding: 16rpx 18rpx 18rpx;
}

.h-top {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.h-title {
  flex: 1;
  min-width: 0;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #2f261f;
  margin-bottom: 6rpx;
  white-space: normal;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.h-desc {
  font-size: 26rpx;
  line-height: 1.22;
  font-weight: 600;
  color: #f06a23;
}

.h-distance {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #7f7268;
}

.favorite-chip-wrap {
  flex-shrink: 0;
}

.hot-properties-section {
  margin-top: 4rpx;
}

.strategy-text {
  margin: -2rpx 8rpx 12rpx;
  font-size: 22rpx;
  color: #7f7268;
}

.property-item {
  display: flex;
  align-items: stretch;
  margin: 0 4rpx 14rpx;
  padding: 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 10rpx 24rpx rgba(92, 64, 51, 0.12);
  border: none;
}

.item-img {
  width: 178rpx;
  height: 118rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  border-radius: 14rpx;
  background: #ebe5dc;
}

.item-img-placeholder {
  background: linear-gradient(145deg, #efe9df 0%, #e4d9cb 100%);
}

.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-title {
  font-size: 34rpx;
  line-height: 1.28;
  font-weight: 600;
  color: #2f261f;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-desc {
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #f06a23;
}

.item-distance {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #7f7268;
}

.property-fav-wrap {
  margin-left: 10rpx;
  align-self: flex-start;
}

.empty-block {
  margin: 0 4rpx;
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 10rpx 24rpx rgba(92, 64, 51, 0.12);
  border: none;
  font-size: 26rpx;
  color: #6e6056;
}

.card-hover {
  box-shadow: 0 14rpx 30rpx rgba(92, 64, 51, 0.2) !important;
}
