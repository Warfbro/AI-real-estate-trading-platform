.format-tabs {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
}

.btn-type {
  flex: 1;
  border-radius: 16rpx;
  border: 2rpx solid rgba(198, 212, 234, 0.96);
  background: rgba(255, 255, 255, 0.96);
  color: #31507b;
  margin: 0;
  padding: 12rpx 0;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-type-active {
  background: linear-gradient(180deg, #ff9a57 0%, #ff651c 100%);
  color: #ffffff;
  border-color: transparent;
}

.image-upload-area {
  width: 100%;
  height: 300rpx;
  border: 2rpx dashed #8eaed8;
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.94);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-placeholder {
  color: #6b7a8f;
  font-size: 28rpx;
  font-weight: bold;
}

.upload-preview {
  width: 100%;
  height: 100%;
}
