.format-tabs {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
}

.btn-type {
  flex: 1;
  border-radius: 16rpx;
  border: 2rpx solid #E4D4C8;
  background: #ffffff;
  color: #5C4033;
  margin: 0;
  padding: 12rpx 0;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-type-active {
  background: #5C4033;
  color: #ffffff;
  border-color: #5C4033;
}

.image-upload-area {
  width: 100%;
  height: 300rpx;
  border: 2rpx dashed #5C4033;
  border-radius: 16rpx;
  background-color: #F7F8FA;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-placeholder {
  color: #5C4033;
  font-size: 28rpx;
  font-weight: bold;
}

.upload-preview {
  width: 100%;
  height: 100%;
}
