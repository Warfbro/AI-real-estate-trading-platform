<view class="page">
  <view class="title">了解您的安家期望</view>
  <view class="subtitle">花一分钟写下需求，AI 将为您精准锚定目标并展开后续分析。</view>

  <view class="card">
    <view class="label">一句话描述您的理想家</view>
    <textarea
      class="textarea"
      placeholder="例如：预算 350 万以内，优先 3 房，通勤 45 分钟内，最好有电梯。"
      value="{{raw_text}}"
      data-field="raw_text"
      bindinput="handleInput"
    />
  </view>

  <view class="card">
    <view class="label">期望城市</view>
    <input
      class="input"
      placeholder="请输入城市名称"
      value="{{city}}"
      data-field="city"
      bindinput="handleInput"
    />

    <view class="label">预算区间（万元）</view>
    <view class="row">
      <input
        class="input"
        type="number"
        placeholder="下限"
        value="{{budget_min}}"
        data-field="budget_min"
        bindinput="handleInput"
      />
      <input
        class="input"
        type="number"
        placeholder="上限"
        value="{{budget_max}}"
        data-field="budget_max"
        bindinput="handleInput"
      />
    </view>

    <view class="label">计划用途</view>
    <picker mode="selector" range="{{usage_options}}" value="{{usage_index}}" bindchange="handleUsageChange">
      <view class="picker">{{usage_type}}</view>
    </picker>

    <view class="label">选房最大的顾虑是什么？</view>
    <input
      class="input"
      placeholder="例如：首付压力、学区政策、通勤时间..."
      value="{{max_concern}}"
      data-field="max_concern"
      bindinput="handleInput"
    />
  </view>

  <button class="btn-primary" bindtap="handleSaveContinue">保存并继续</button>
</view>
