.label {
  margin-top: 32rpx;
}

.label:first-child {
  margin-top: 0;
}

.row {
  display: flex;
  justify-content: space-between;
}

.row .input {
  width: 48%;
}

.picker {
  width: 100%;
  border: 2rpx solid #E4D4C8;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 20rpx;
  box-sizing: border-box;
  color: #333333;
}
