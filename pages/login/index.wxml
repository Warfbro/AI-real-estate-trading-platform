<view class="page login-page">
  <view class="login-shell">
    <view class="brand-area">
      <view class="brand-mark">AI</view>
      <view class="brand-title">AI 买房助手</view>
    </view>

    <view class="action-panel">
      <button
        wx:if="{{!is_devtools}}"
        class="btn-primary login-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="handleQuickLogin"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        {{loading ? '登录中...' : primary_login_text}}
      </button>
      <button
        wx:else
        class="btn-primary login-btn"
        bindtap="handleDevtoolsLogin"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        {{loading ? '登录中...' : primary_login_text}}
      </button>
      <view class="helper-text" wx:if="{{helper_text}}">{{helper_text}}</view>
      <view class="status-text" wx:if="{{status_text}}">{{status_text}}</view>
      <view class="error-text" wx:if="{{error_text}}">{{error_text}}</view>
    </view>
  </view>
</view>
