page {
  background: #faf8f5;
}

.favorites-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.favorites-card {
  margin-top: 10rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid rgba(92, 64, 51, 0.16);
  box-shadow: 0 12rpx 28rpx rgba(92, 64, 51, 0.08);
  padding: 22rpx;
  box-sizing: border-box;
}

.favorites-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.favorites-title {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #4a3328;
}

.favorites-edit {
  min-width: 88rpx;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #efe1d4;
  color: #4a3328;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.favorites-empty {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7d6f64;
  line-height: 1.5;
}

.favorite-item {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #fffdf9;
  border: 1rpx solid rgba(92, 64, 51, 0.14);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.favorite-main {
  flex: 1;
  min-width: 0;
}

.favorite-name {
  font-size: 28rpx;
  line-height: 1.28;
  font-weight: 600;
  color: #2f261f;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.favorite-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7a6c61;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.favorite-price {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
  color: #ef7236;
}

.favorite-remove {
  flex-shrink: 0;
  min-width: 88rpx;
  height: 52rpx;
  padding: 0 14rpx;
  border-radius: 12rpx;
  background: #fbe7dd;
  border: 1rpx solid rgba(201, 74, 30, 0.25);
  color: #c14a1e;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

