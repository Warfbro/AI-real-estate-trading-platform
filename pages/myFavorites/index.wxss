page {
  background:
    radial-gradient(
      130% 72% at 12% -10%,
      rgba(199, 212, 230, 0.82) 0%,
      rgba(213, 224, 238, 0.66) 34%,
      rgba(242, 236, 225, 0.18) 72%,
      rgba(248, 243, 234, 0) 100%
    ),
    linear-gradient(180deg, #d9e3f0 0%, #e2e9f2 30%, #eef1f4 58%, #f7f4ed 100%);
}

.favorites-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.favorites-card {
  margin-top: 10rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid rgba(205, 217, 235, 0.96);
  box-shadow: 0 12rpx 28rpx rgba(102, 123, 156, 0.12);
  padding: 22rpx;
  box-sizing: border-box;
}

.favorites-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.favorites-title {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #243247;
}

.favorites-edit {
  min-width: 88rpx;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(214, 224, 239, 0.92);
  color: #31507b;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.favorites-empty {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f7f93;
  line-height: 1.5;
}

.favorite-item {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(205, 217, 235, 0.96);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.favorite-main {
  flex: 1;
  min-width: 0;
}

.favorite-name {
  font-size: 28rpx;
  line-height: 1.28;
  font-weight: 600;
  color: #243247;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.favorite-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6f7f93;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.favorite-price {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
  color: #ef7236;
}

.favorite-remove {
  flex-shrink: 0;
  min-width: 88rpx;
  height: 52rpx;
  padding: 0 14rpx;
  border-radius: 12rpx;
  background: #fbe7dd;
  border: 1rpx solid rgba(201, 74, 30, 0.25);
  color: #c14a1e;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
