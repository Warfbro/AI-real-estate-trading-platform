.risk-item {
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 12rpx;
}

.risk-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.warn {
  color: #b91c1c;
}

.row .btn-primary,
.row .btn-secondary {
  width: auto;
  flex: 1;
  margin-bottom: 0;
}
