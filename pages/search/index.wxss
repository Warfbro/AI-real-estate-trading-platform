.search-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 18rpx 24rpx calc(64rpx + env(safe-area-inset-bottom));
  background: #f7f8fa;
}

.search-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.head-back {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 44rpx;
  font-weight: 300;
  color: #5f5f5f;
}

.head-input-wrap {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #e6e6e6;
  box-sizing: border-box;
}

.head-input {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  color: #2f2f2f;
}

.head-submit {
  min-width: 68rpx;
  text-align: center;
  font-size: 28rpx;
  color: #e26f2f;
  font-weight: 600;
}

.history-section {
  margin-top: 34rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.history-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.history-clear {
  font-size: 24rpx;
  color: #9a9a9a;
}

.history-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  max-width: 100%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #5f5f5f;
  background: #ededed;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.history-empty {
  font-size: 24rpx;
  color: #9a9a9a;
  line-height: 1.6;
}
