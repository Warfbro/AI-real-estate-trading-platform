<view class="page">
  <view class="top-shell">
    <view class="search-alone">
      <icon class="search-icon" type="search" size="16" color="#6B7A8F" />
      <input
        class="search-input"
        placeholder="搜索小区、地铁、关键词"
        value="{{filter_keyword}}"
        data-field="filter_keyword"
        bindinput="handleFilterInput"
        bindconfirm="handleSearchConfirm"
        confirm-type="search"
      />
    </view>

    <view class="menu-row">
      <picker class="menu-picker" mode="region" value="{{search_region_value}}" bindchange="handleRegionChange">
        <view class="menu-item">
          <text class="menu-text">位置：{{search_region_text}}</text>
          <text class="menu-arrow">⌄</text>
        </view>
      </picker>
      <view class="menu-item" bindtap="handlePickPrice">
        <text class="menu-text">{{budget_menu_text}}</text>
        <text class="menu-arrow">⌄</text>
      </view>
      <view class="menu-item" bindtap="handlePickLayout">
        <text class="menu-text">户型</text>
        <text class="menu-arrow">⌄</text>
      </view>
    </view>
    <view class="menu-clear-row" wx:if="{{has_region_selected}}">
      <view class="menu-clear-btn" bindtap="handleClearRegion">清除</view>
    </view>
  </view>

  <view class="ai-guide">
    <view class="guide-text">点击收藏，让ai帮你比较</view>
    <view class="guide-btn" bindtap="handleGoAI">AI比较</view>
  </view>

  <view class="empty-card" wx:if="{{show_empty_list}}">
    <view class="empty-title">{{empty_title}}</view>
    <view class="empty-desc">{{empty_desc}}</view>
    <view class="empty-btn" wx:if="{{!has_source_listings}}" bindtap="handleGoImport">去导入房源</view>
  </view>

  <block wx:for="{{listings}}" wx:key="listing_id">
    <view class="listing-card" bindtap="handleOpenDetail" data-listing-id="{{item.listing_id}}">
      <image class="listing-image" src="{{item.cover_image_url}}" mode="aspectFill" />

      <view class="listing-main">
        <view class="listing-topline">
          <text class="listing-badge">{{item.display_badge}}</text>
          <view
            class="favorite-chip-wrap"
            catchtap="handleToggleFavorite"
            data-listing-id="{{item.listing_id}}"
          >
            <view class="favorite-chip {{item.is_favorited ? 'favorite-chip-on' : ''}}">
              {{item.favorite_text}}
            </view>
          </view>
        </view>

        <view class="listing-title">{{item.display_title}}</view>
        <view class="listing-meta">{{item.display_meta}}</view>
        <view class="listing-location">{{item.display_location}}</view>

        <view class="listing-tags" wx:if="{{item.display_tags.length}}">
          <text class="listing-tag" wx:for="{{item.display_tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>

        <view class="listing-bottom">
          <view class="listing-price">{{item.display_price}}</view>
          <view class="listing-reason">{{item.recommendation_reason}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
