.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 18rpx 18rpx calc(220rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(
      130% 72% at 12% -10%,
      rgba(199, 212, 230, 0.95) 0%,
      rgba(213, 224, 238, 0.82) 35%,
      rgba(236, 234, 227, 0.25) 72%,
      rgba(245, 240, 231, 0) 100%
    ),
    linear-gradient(
      180deg,
      #d6e0ef 0%,
      #dde6f2 28%,
      #e7e8e7 52%,
      #f2ece1 74%,
      #f8f3ea 100%
    );
}

.top-shell,
.ai-guide,
.empty-card,
.listing-card {
  margin-top: 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 10rpx 24rpx rgba(92, 64, 51, 0.12);
  border: 1rpx solid rgba(233, 224, 214, 0.85);
}

.top-shell {
  margin-top: 0;
  padding: 14rpx;
}

.search-alone {
  height: 60rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  box-sizing: border-box;
  background: rgba(245, 246, 248, 0.96);
  border: 1rpx solid rgba(180, 186, 194, 0.58);
}

.search-icon {
  margin-right: 8rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  color: #3d2e24;
}

.menu-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  border-top: 1rpx solid rgba(220, 214, 205, 0.8);
  padding-top: 12rpx;
}

.menu-picker {
  flex: 1;
  min-width: 0;
}

.menu-item {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #2f241d;
  font-size: 27rpx;
  font-weight: 600;
}

.menu-text {
  max-width: 82%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-arrow {
  font-size: 19rpx;
  color: #6f6259;
}

.menu-clear-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
}

.menu-clear-btn {
  font-size: 22rpx;
  color: #8f8379;
}

.ai-guide {
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.guide-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #3d2f26;
  font-weight: 600;
}

.guide-btn {
  flex-shrink: 0;
  min-width: 176rpx;
  height: 62rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #4e382c;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(78, 56, 44, 0.24);
}

.empty-card {
  padding: 20rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #3d2e24;
  font-weight: 700;
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #7a6d62;
  line-height: 1.45;
}

.empty-btn {
  margin-top: 14rpx;
  height: 62rpx;
  border-radius: 14rpx;
  background: rgba(214, 224, 239, 0.92);
  color: #31507b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 700;
}

.listing-card {
  display: flex;
  gap: 14rpx;
  padding: 16rpx;
  align-items: stretch;
}

.listing-image {
  width: 216rpx;
  height: 154rpx;
  border-radius: 14rpx;
  background: linear-gradient(145deg, #efe9df 0%, #e4d9cb 100%);
  flex-shrink: 0;
}

.listing-main {
  flex: 1;
  min-width: 0;
}

.listing-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.listing-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 12rpx;
  border-radius: 10rpx;
  background: #f36b40;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.favorite-chip-wrap {
  flex-shrink: 0;
}

.favorite-chip {
  min-width: 108rpx;
  height: 42rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(214, 224, 239, 0.9);
  color: #31507b;
  font-size: 20rpx;
  font-weight: 700;
}

.favorite-chip-on {
  background: rgba(240, 106, 35, 0.14);
  color: #f06a23;
}

.listing-title {
  margin-top: 8rpx;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #2f261f;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.listing-meta,
.listing-location {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #7b6d62;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.listing-tags {
  margin-top: 6rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.listing-tag {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #eef4f8;
  color: #5b6f80;
  font-size: 18rpx;
}

.listing-bottom {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.listing-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #ef7236;
  line-height: 1;
  white-space: nowrap;
}

.listing-reason {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 20rpx;
  color: #8a7c71;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
